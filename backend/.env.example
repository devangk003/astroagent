# AstroAgent — backend environment template.
# Copy this file to .env and fill in your keys. NEVER commit the real .env.
#
# ── How config works ──────────────────────────────────────────────────────────
# • API keys are set ONCE per provider (below). Either provider works anywhere.
# • Every "checkpoint" (agent / eval base / sweep / judge) independently picks a
#   PROVIDER (ollama | openrouter) + MODEL. The provider selects which key is used.
# • The frontend model selector (BYOK) overrides the AGENT provider/model/key per session.
# • OpenRouter models must be real OpenRouter slugs (e.g. anthropic/claude-haiku-4.5),
#   NOT Anthropic-API ids (e.g. ...-20251001). Ollama models are Ollama Cloud tags.

# ── API keys (set once each; at least one required) ────────────────────────────
OPENROUTER_API_KEY=
OLLAMA_API_KEY=

# ── Agent (the live app) ───────────────────────────────────────────────────────
# Keep in sync with the frontend default (frontend/context/model-config-context.tsx).
DEFAULT_PROVIDER=ollama
DEFAULT_MODEL=qwen3.5:397b

# ── Evaluation harness (eval/run_eval.py, eval/run_guardrail_eval.py) ──────────
# Base model under test. Falls back to DEFAULT_PROVIDER/DEFAULT_MODEL if unset.
EVAL_PROVIDER=ollama
EVAL_MODEL=qwen3.5:397b

# Sweep: a SECOND model to compare in the eval. Any provider. Runs only when SWEEP_MODEL
# is set AND that provider's key is set. Example (OpenRouter): anthropic/claude-haiku-4.5
SWEEP_PROVIDER=
SWEEP_MODEL=
# Optional cost accounting for the sweep model ($/1k tokens), for $ in the scorecard.
# SWEEP_INPUT_COST_PER_1K=0.0008
# SWEEP_OUTPUT_COST_PER_1K=0.004

# Judge (tone + guardrail compliance). Any provider; defaults to openrouter if JUDGE_PROVIDER
# unset. Uses that provider's key above. Judge is skipped unless JUDGE_MODEL + its key are set.
# RECOMMENDED: pick a DIFFERENT family than the agent for unbiased scoring.
# Example: JUDGE_PROVIDER=openrouter  JUDGE_MODEL=anthropic/claude-haiku-4.5
JUDGE_PROVIDER=openrouter
JUDGE_MODEL=
